{{ 'https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Mulish:wght@300;400;500;600;700&display=swap' | stylesheet_tag }}

<style>
:root{
  --ink:#0d0d0b;--ink2:#252520;--ink3:#4a4a44;--ink4:#8a8a82;--ink5:#b8b8b0;
  --white:#fff;--snow:#f9f8f6;--fog:#f3f1ed;--fog2:#e8e5de;--rule:#dedad2;--rule2:#c8c4ba;
  --nav{y:#0f1f35;--navy2:#1a3050;
  --gold:#b09060;--gold2:#c8aa78;
  --green:#1a7a3a;
  --red:#c0392b;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--white);color:var(--ink);font-family:'Mulish',sans-serif;font-size:15px;line-height:1.7;-webkit-font-smoothing:antialiased;overflow-x:hidden;padding-bottom:80px;}

/* URGENCY */
.cs-urgency{background:var(--navy);color:#fff;padding:9px 16px;text-align:center;font-size:11px;font-weight:600;letter-spacing:1px;display:flex;align-items:center;justify-content:center;gap:10px;position:sticky;top:0;z-index:200;}
.u-dot{width:6px;height:6px;border-radius:50%;background:#25D366;flex-shrink:0;animation:blink 1.4s ease-in-out infinite;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:.35;}}
.u-timer{background:rgba(255,255,255,.14);padding:2px 10px;font-weight:700;letter-spacing:1.5px;border-radius:2px;}

/* NAV */
.cs-nav{border-bottom:1px solid var(--rule);padding:0 18px;height:64px;display:flex;align-items:center;justify-content:space-between;background:var(--white);}
.nav-logo{
  font-family:'Cormorant Garamond',serif;
  font-size:22px;font-weight:600;
  font-variant:small-caps;
  letter-spacing:6px;
  text-transform:uppercase;
  color:var(--ink);text-decoration:none;
  line-height:1.1;text-align:center;
  display:flex;flex-direction:column;align-items:center;
}
.nav-logo-sub{
  display:flex;align-items:center;gap:6px;
  font-family:'Mulish',sans-serif;
  font-size:9px;font-weight:400;font-variant:normal;
  letter-spacing:3px;color:var(--ink3);
  text-transform:uppercase;margin-top:2px;
}
.nav-logo-sub::before,.nav-logo-sub::after{
  content:'';display:block;
  width:22px;height:1px;background:var(--ink3);
}
.nav-cart-btn{position:relative;width:40px;height:40px;display:flex;align-items:center;justify-content:center;cursor:pointer;background:none;border:none;}
.nav-cart-btn svg{width:22px;height:22px;stroke:var(--ink);fill:none;stroke-width:1.5;}
.nav-cart-count{position:absolute;top:4px;right:4px;width:16px;height:16px;border-radius:50%;background:var(--red);color:#fff;font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;line-height:1;}

/* HERO CAROUSEL */
.cs-hero{width:100%;aspect-ratio:1/1;overflow:hidden;position:relative;background:var(--fog);}
.cs-carousel-track{display:flex;height:100%;transition:transform .35s cubic-bezier(.4,0,.2,1);will-change:transform;}
.cs-carousel-slide{min-width:100%;height:100%;flex-shrink:0;}
.cs-carousel-slide img{width:100%;height:100%;object-fit:cover;display:block;}
.hero-disc-badge{position:absolute;top:14px;left:14px;background:var(--red);color:#fff;font-size:10px;font-weight:700;letter-spacing:2px;padding:5px 12px;z-index:2;}
.cs-carousel-dots{position:absolute;bottom:10px;left:50%;transform:translateX(-50%);display:flex;gap:6px;z-index:2;}
.cs-carousel-dot{width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,.5);border:none;padding:0;cursor:pointer;transition:background .2s,transform .2s;}
.cs-carousel-dot.active{background:#fff;transform:scale(1.3);}
.cs-carousel-arrow{position:absolute;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.75);border:none;width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;z-index:3;transition:background .2s;}
.cs-carousel-arrow:hover{background:#fff;}
.cs-carousel-arrow svg{width:16px;height:16px;stroke:var(--ink);fill:none;stroke-width:2.5;}
.cs-carousel-arrow.prev{left:10px;}
.cs-carousel-arrow.next{right:10px;}

/* PRODUCT INFO */
.product-info{padding:20px 16px 0;}
.pi-eyebrow{font-size:9px;font-weight:700;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:8px;display:flex;align-items:center;gap:8px;}
.pi-eyebrow::before{content:'';display:block;width:14px;height:1px;background:var(--gold);}
.pi-title{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:700;line-height:1.1;color:var(--ink);margin-bottom:10px;}
.pi-title em{font-style:italic;font-weight:400;color:var(--ink3);}
.pi-stars{display:flex;align-items:center;gap:6px;margin-bottom:14px;}
.pi-stars .stars{color:var(--gold);font-size:13px;letter-spacing:2px;}
.pi-stars span{font-size:12px;color:var(--ink4);}

/* PRICE */
.price-wrap{background:var(--fog);border-radius:8px;padding:16px;margin-bottom:16px;}
.price-was{font-size:12px;color:var(--ink4);text-decoration:line-through;font-weight:300;margin-bottom:3px;}
.price-row{display:flex;align-items:center;gap:10px;margin-bottom:6px;}
.price-now{font-family:'Cormorant Garamond',serif;font-size:36px;font-weight:700;color:var(--ink);line-height:1;}
.price-save{background:var(--red);color:#fff;font-size:9px;font-weight:700;letter-spacing:1.5px;padding:3px 9px;}
.price-ship{font-size:12px;color:var(--green);font-weight:600;display:flex;align-items:center;gap:4px;}
.price-ship svg{width:12px;height:12px;stroke:currentColor;fill:none;stroke-width:2;}

/* QTY CARDS */
.qty-section{margin-bottom:16px;}
.qty-label{font-size:10px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--ink3);margin-bottom:10px;}
.qty-grid{display:flex;flex-direction:column;gap:8px;}
.qty-card{border:1.5px solid var(--rule);border-radius:8px;padding:12px 14px;cursor:pointer;display:flex;align-items:center;justify-content:space-between;gap:12px;transition:border-color .2s,background .2s;position:relative;}
.qty-card:hover{border-color:var(--navy);}
.qty-card.selected{border-color:var(--navy);background:var(--snow);}
.qty-card.popular{border-color:var(--gold);}
.qty-badge{position:absolute;top:-9px;left:14px;background:var(--gold);color:var(--navy);font-size:8px;font-weight:700;letter-spacing:2px;padding:2px 10px;}
.qty-radio{width:18px;height:18px;border-radius:50%;border:2px solid var(--rule2);flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:border-color .2s;}
.qty-card.selected .qty-radio{border-color:var(--navy);background:var(--navy);}
.qty-radio::after{content:'';width:7px;height:7px;border-radius:50%;background:var(--white);opacity:0;transition:opacity .15s;}
.qty-card.selected .qty-radio::after{opacity:1;}
.qty-info{flex:1;}
.qty-info strong{font-size:13px;font-weight:600;color:var(--ink);display:block;}
.qty-info span{font-size:11px;font-weight:300;color:var(--ink4);}
.qty-price-col{text-align:right;}
.qty-price{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:700;color:var(--ink);line-height:1;}
.qty-per{font-size:10px;color:var(--ink4);font-weight:300;}
.qty-save-chip{font-size:9px;font-weight:700;color:var(--red);letter-spacing:.5px;}

/* VARIANTS inside qty-section */
.cs-variant-block{padding:12px 14px;background:var(--snow);border:1px solid var(--rule);border-radius:8px;margin-bottom:8px;}
.cs-variant-label{font-size:10px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--ink3);margin-bottom:8px;display:flex;align-items:center;gap:6px;}
.cs-variant-selected{font-weight:600;font-size:12px;color:var(--navy);letter-spacing:0;text-transform:none;}
.cs-variant-opts{display:flex;flex-wrap:wrap;gap:6px;}
.cs-variant-btn{padding:6px 14px;border:1.5px solid var(--rule2);background:var(--white);color:var(--ink);font-size:12px;font-weight:500;cursor:pointer;border-radius:4px;transition:border-color .2s,background .2s,color .2s;}
.cs-variant-btn:hover:not(.unavailable){border-color:var(--navy);}
.cs-variant-btn.active{border-color:var(--navy);background:var(--navy);color:#fff;}
.cs-variant-btn.unavailable{opacity:.35;cursor:not-allowed;text-decoration:line-through;}
.cs-stock-msg{font-size:11px;font-weight:600;margin-top:8px;}
.cs-stock-msg.low{color:var(--red);}
.cs-stock-msg.ok{color:var(--green);}

/* BUTTONS */
.btn-wrap{display:flex;flex-direction:column;gap:2px;margin-bottom:14px;}
.btn-cart{width:100%;padding:14px;border:2px solid var(--navy);background:var(--white);color:var(--navy);font-size:12px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;cursor:pointer;transition:background .2s,color .2s;display:flex;align-items:center;justify-content:center;gap:8px;}
.btn-cart:hover,.btn-cart.loading{background:var(--navy);color:#fff;}
.btn-buy{width:100%;padding:14px;border:none;background:var(--navy);color:#fff;font-size:12px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;cursor:pointer;transition:background .2s,transform .1s;display:flex;align-items:center;justify-content:center;gap:8px;text-decoration:none;}
.btn-buy:hover{background:var(--navy2);transform:translateY(-1px);}
.btn-feedback{font-size:11px;color:var(--green);font-weight:600;text-align:center;min-height:16px;transition:opacity .3s;}

/* PAYMENT */
.pay-row{display:flex;align-items:center;justify-content:center;gap:6px;flex-wrap:wrap;padding:10px 0 16px;border-top:1px solid var(--rule);border-bottom:1px solid var(--rule);margin-bottom:20px;}
.pay-badge{font-size:10px;font-weight:600;color:var(--ink4);border:1px solid var(--rule);padding:4px 10px;}

/* TRUST */
.trust-strip{display:grid;grid-template-columns:repeat(3,1fr);gap:0;border:1px solid var(--rule);margin-bottom:24px;}
.trust-item{padding:14px 8px;text-align:center;border-right:1px solid var(--rule);}
.trust-item:last-child{border-right:none;}
.trust-item svg{width:18px;height:18px;stroke:var(--green);fill:none;stroke-width:1.5;margin:0 auto 5px;display:block;}
.trust-item strong{font-size:11px;font-weight:600;color:var(--ink);display:block;}
.trust-item span{font-size:10px;font-weight:300;color:var(--ink4);}

/* SECTIONS */
.cs-sec{padding:32px 16px;border-top:1px solid var(--rule);}
.sec-eyebrow{font-size:9px;font-weight:700;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:8px;display:flex;align-items:center;gap:8px;}
.sec-eyebrow::before{content:'';display:block;width:14px;height:1px;background:var(--gold);}
.sec-title{font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:700;color:var(--ink);line-height:1.12;margin-bottom:8px;}
.sec-title em{font-style:italic;font-weight:400;}
.sec-body{font-size:14px;font-weight:300;color:var(--ink3);line-height:1.75;}

/* PROBLEMS */
.prob-list{display:flex;flex-direction:column;margin-top:16px;}
.prob-item{display:flex;gap:12px;padding:13px 0;border-bottom:1px solid var(--rule);align-items:flex-start;}
.prob-icon{font-size:18px;flex-shrink:0;padding-top:1px;}
.prob-text strong{display:block;font-size:13px;font-weight:600;color:var(--ink);margin-bottom:2px;}
.prob-text span{font-size:12px;font-weight:300;color:var(--ink3);}

/* MECHANISM */
.mech-list{display:flex;flex-direction:column;gap:2px;background:var(--rule);margin-top:16px;}
.mech-card{background:var(--white);padding:20px 16px;}
.mech-chip{display:inline-block;font-size:8px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;background:var(--navy);color:var(--gold2);padding:3px 9px;margin-bottom:10px;}
.mech-card h4{font-family:'Cormorant Garamond',serif;font-size:19px;font-weight:700;color:var(--ink);margin-bottom:7px;}
.mech-card p{font-size:13px;font-weight:300;color:var(--ink3);line-height:1.7;}

/* LIFESTYLE */
.life-stack{display:flex;flex-direction:column;gap:8px;margin-top:16px;}
.life-img{width:100%;overflow:hidden;border-radius:2px;position:relative;}
.life-img img{width:100%;height:260px;object-fit:cover;display:block;}
.life-cap{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(13,13,11,.5));padding:14px 14px 10px;color:#fff;font-size:11px;font-weight:600;letter-spacing:.5px;}

/* REVIEWS */
.reviews-summary{display:flex;align-items:center;gap:14px;background:var(--fog);padding:14px 16px;margin-top:16px;border-radius:4px;}
.review-big{font-family:'Cormorant Garamond',serif;font-size:44px;font-weight:700;color:var(--ink);line-height:1;}
.review-right .stars{color:var(--gold);font-size:15px;letter-spacing:2px;}
.review-right p{font-size:11px;font-weight:300;color:var(--ink4);margin-top:2px;}
.review-list{display:flex;flex-direction:column;gap:0;margin-top:12px;}
.review-card{padding:16px 0;border-bottom:1px solid var(--rule);}
.review-card:last-child{border-bottom:none;}
.review-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;}
.review-stars{color:var(--gold);font-size:12px;letter-spacing:1.5px;}
.review-date{font-size:10px;color:var(--ink5);}
.review-name{font-size:12px;font-weight:600;color:var(--ink2);margin-bottom:5px;}
.review-text{font-size:13px;font-weight:300;color:var(--ink3);line-height:1.65;font-style:italic;}
.review-verified{font-size:10px;color:var(--green);margin-top:5px;}

/* GUARANTEE */
.guar-box{border:1px solid var(--rule);padding:24px 16px;text-align:center;background:var(--fog);border-radius:4px;margin-top:16px;}
.guar-icon{font-size:36px;margin-bottom:12px;}
.guar-box h3{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:700;color:var(--ink);margin-bottom:10px;}
.guar-box p{font-size:13px;font-weight:300;color:var(--ink3);line-height:1.7;margin-bottom:16px;}
.g-chips{display:flex;flex-wrap:wrap;justify-content:center;gap:6px;}
.g-chip{font-size:9px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;border:1px solid var(--rule2);padding:5px 10px;color:var(--ink3);}

/* FAQ */
.faq-item{border-bottom:1px solid var(--rule);}
.faq-q{display:flex;align-items:center;justify-content:space-between;padding:15px 0;cursor:pointer;font-size:14px;font-weight:500;color:var(--ink);gap:12px;user-select:none;}
.faq-arrow{font-size:18px;color:var(--ink4);transition:transform .3s;flex-shrink:0;}
.faq-a{max-height:0;overflow:hidden;transition:max-height .35s ease;}
.faq-a-inner{padding:0 0 14px;font-size:13px;font-weight:300;color:var(--ink3);line-height:1.75;}
.faq-item.open .faq-arrow{transform:rotate(45deg);}
.faq-item.open .faq-a{max-height:400px;}

/* STICKY BOTTOM */
.cs-sticky{position:fixed;bottom:0;left:0;right:0;background:var(--white);border-top:1px solid var(--rule);padding:10px 16px;display:flex;align-items:center;gap:8px;z-index:100;box-shadow:0 -4px 20px rgba(0,0,0,.07);}
.sb-price{flex-shrink:0;}
.sb-was{font-size:10px;color:var(--ink4);text-decoration:line-through;display:block;}
.sb-now{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:700;color:var(--ink);display:block;line-height:1;}
.sb-buy{flex:1;background:var(--navy);color:#fff;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;padding:13px 10px;border:none;cursor:pointer;transition:background .2s;text-align:center;}
.sb-buy:hover{background:var(--navy2);}
.sb-cart-btn{flex-shrink:0;width:46px;height:46px;border:1.5px solid var(--rule2);background:var(--white);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:border-color .2s;}
.sb-cart-btn:hover{border-color:var(--navy);}
.sb-cart-btn svg{width:18px;height:18px;stroke:var(--ink2);fill:none;stroke-width:1.5;}

/* FOOTER */
.cs-footer{background:var(--fog);border-top:1px solid var(--rule);padding:18px 16px;}
.lp-footer-logo{font-family:'Cormorant Garamond',serif;font-size:16px;font-weight:600;font-variant:small-caps;letter-spacing:6px;text-transform:uppercase;color:var(--ink);display:flex;flex-direction:column;align-items:flex-start;gap:3px;margin-bottom:14px;}
.lp-footer-logo-sub{display:flex;align-items:center;gap:5px;font-family:'Mulish',sans-serif;font-size:8px;font-weight:400;font-variant:normal;letter-spacing:3px;color:var(--ink4);text-transform:uppercase;}
.lp-footer-logo-sub::before,.lp-footer-logo-sub::after{content:'';display:block;width:16px;height:1px;background:var(--ink4);}
.lp-links{display:flex;flex-wrap:wrap;gap:12px 18px;list-style:none;margin-bottom:14px;}
.lp-links a{font-size:10px;font-weight:400;letter-spacing:1.5px;text-transform:uppercase;color:var(--ink4);text-decoration:none;display:inline-flex;align-items:center;gap:4px;}
.lp-links a:hover{color:var(--ink);}
.lp-copy{font-size:10px;font-weight:300;color:var(--ink5);}
</style>

{%- assign product = all_products[section.settings.product] -%}
{%- assign variant_1 = product.variants[0] -%}
{%- assign variant_2 = product.variants[1] -%}
{%- assign variant_3 = product.variants[2] -%}

<!-- URGENCY -->
<div class="cs-urgency">
  <span class="u-dot"></span>
  <span>{{ section.settings.urgency_text }}</span>
  <span class="u-timer" id="cs-timer">{{ section.settings.timer_start }}</span>
</div>

<!-- NAV -->
<nav class="cs-nav">
  <a href="{{ section.settings.url_tienda | default: '/' }}" class="nav-logo">
    {{ section.settings.logo_text }}
    <span class="nav-logo-sub">{{ section.settings.logo_sub }}</span>
  </a>
  <button class="nav-cart-btn" id="cs-nav-cart-btn" aria-label="Carrito">
    <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
    <span class="nav-cart-count" id="cs-cart-count">0</span>
  </button>
</nav>

<!-- HERO CAROUSEL -->
{%- assign hero_images = '' | split: ',' -%}
{%- for i in (1..6) -%}
  {%- assign img_key = 'hero_image' -%}
  {%- if i > 1 -%}{%- assign img_key = 'hero_image_' | append: i -%}{%- endif -%}
  {%- if section.settings[img_key] != blank -%}
    {%- assign hero_images = hero_images | push: img_key -%}
  {%- endif -%}
{%- endfor -%}

<div class="cs-hero" id="cs-hero-carousel">
  <div class="cs-carousel-track" id="cs-carousel-track">
    {%- if hero_images.size > 0 -%}
      {%- for img_key in hero_images -%}
        <div class="cs-carousel-slide">
          <img src="{{ section.settings[img_key] | img_url: 'master' }}"
               alt="{{ section.settings[img_key].alt | default: section.settings.product_name }}"
               loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="cs-carousel-slide">
        <img src="{{ 'cs-hero-product.png' | asset_url }}" alt="{{ section.settings.product_name }}" loading="eager">
      </div>
    {%- endif -%}
  </div>
  {%- if section.settings.hero_badge != blank -%}
    <span class="hero-disc-badge">{{ section.settings.hero_badge }}</span>
  {%- endif -%}
  {%- if hero_images.size > 1 -%}
    <button class="cs-carousel-arrow prev" onclick="csCarouselGoTo(window._csCarouselIdx - 1)" aria-label="Anterior">
      <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button class="cs-carousel-arrow next" onclick="csCarouselGoTo(window._csCarouselIdx + 1)" aria-label="Siguiente">
      <svg viewBox="0 0 24 24"><polyline points="9 6 15 12 9 18"/></svg>
    </button>
    <div class="cs-carousel-dots" id="cs-carousel-dots">
      {%- for img_key in hero_images -%}
        <button class="cs-carousel-dot{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}" onclick="csCarouselGoTo({{ forloop.index0 }})"></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

<!-- PRODUCT INFO -->
<div class="product-info">
  <div class="pi-eyebrow">{{ section.settings.product_eyebrow }}</div>
  <h1 class="pi-title">{{ section.settings.product_name }}<br><em>{{ section.settings.product_subtitle }}</em></h1>
  <div class="pi-stars">
    <span class="stars">★★★★★</span>
    <span>{{ section.settings.review_score }} / 5 &nbsp;·&nbsp; {{ section.settings.review_count }}</span>
  </div>

  <!-- PRICE -->
  <div class="price-wrap">
    <div class="price-was">{{ section.settings.price_was }}</div>
    <div class="price-row">
      <span class="price-now" id="cs-price-display">{{ section.settings.price_now }}</span>
      {%- if section.settings.price_badge != blank -%}
        <span class="price-save">{{ section.settings.price_badge }}</span>
      {%- endif -%}
    </div>
    <div class="price-ship">
      <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      {{ section.settings.shipping_text }}
    </div>
  </div>

  <!-- QUANTITY + VARIANTS INTEGRADOS -->
  <div class="qty-section">
    <div class="qty-label">{{ section.settings.qty_label }}</div>

    {%- if product != blank and product.options_with_values.size > 0 -%}
      {%- for option in product.options_with_values -%}
      <div class="cs-variant-block">
        <div class="cs-variant-label">
          {{ option.name }}&nbsp;
          <span class="cs-variant-selected" id="cs-opt-val-{{ forloop.index0 }}">{{ option.values.first }}</span>
        </div>
        <div class="cs-variant-opts" data-option-index="{{ forloop.index0 }}">
          {%- for value in option.values -%}
            {%- assign opt_idx = forloop.parentloop.index0 -%}
            {%- comment -%}Check availability for this option value{%- endcomment -%}
            {%- assign value_available = false -%}
            {%- for variant in product.variants -%}
              {%- if variant.options[opt_idx] == value and variant.available -%}
                {%- assign value_available = true -%}
              {%- endif -%}
            {%- endfor -%}
            <button class="cs-variant-btn{% if forloop.first %} active{% endif %}{% unless value_available %} unavailable{% endunless %}"
                    data-value="{{ value }}"
                    data-option="{{ opt_idx }}"
                    data-available="{{ value_available }}"
                    onclick="csSelectOption(this)">{{ value }}</button>
          {%- endfor -%}
        </div>
        <div class="cs-stock-msg" id="cs-stock-msg-{{ forloop.index0 }}"></div>
      </div>
      {%- endfor -%}
    {%- endif -%}

    <div class="qty-grid">

      {%- if section.settings.qty1_title != blank -%}
      <div class="qty-card selected"
           data-qty="1"
           data-price="{{ section.settings.qty1_price }}"
           data-variant-id="{{ section.settings.qty1_variant_id }}"
           onclick="csSelectQty(this)">
        <div class="qty-radio"></div>
        <div class="qty-info">
          <strong>{{ section.settings.qty1_title }}</strong>
          <span>{{ section.settings.qty1_subtitle }}</span>
        </div>
        <div class="qty-price-col">
          <div class="qty-price">{{ section.settings.qty1_price }}</div>
          <div class="qty-per">{{ section.settings.qty1_per }}</div>
        </div>
      </div>
      {%- endif -%}

      {%- if section.settings.qty2_title != blank -%}
      <div class="qty-card popular"
           data-qty="2"
           data-price="{{ section.settings.qty2_price }}"
           data-variant-id="{{ section.settings.qty2_variant_id }}"
           onclick="csSelectQty(this)">
        {%- if section.settings.qty2_badge != blank -%}
          <div class="qty-badge">{{ section.settings.qty2_badge }}</div>
        {%- endif -%}
        <div class="qty-radio"></div>
        <div class="qty-info">
          <strong>{{ section.settings.qty2_title }}</strong>
          <span>{{ section.settings.qty2_subtitle }}</span>
          {%- if section.settings.qty2_save != blank -%}
            <div class="qty-save-chip">{{ section.settings.qty2_save }}</div>
          {%- endif -%}
        </div>
        <div class="qty-price-col">
          <div class="qty-price">{{ section.settings.qty2_price }}</div>
          <div class="qty-per">{{ section.settings.qty2_per }}</div>
        </div>
      </div>
      {%- endif -%}

      {%- if section.settings.qty3_title != blank -%}
      <div class="qty-card"
           data-qty="4"
           data-price="{{ section.settings.qty3_price }}"
           data-variant-id="{{ section.settings.qty3_variant_id }}"
           onclick="csSelectQty(this)">
        <div class="qty-radio"></div>
        <div class="qty-info">
          <strong>{{ section.settings.qty3_title }}</strong>
          <span>{{ section.settings.qty3_subtitle }}</span>
          {%- if section.settings.qty3_save != blank -%}
            <div class="qty-save-chip">{{ section.settings.qty3_save }}</div>
          {%- endif -%}
        </div>
        <div class="qty-price-col">
          <div class="qty-price">{{ section.settings.qty3_price }}</div>
          <div class="qty-per">{{ section.settings.qty3_per }}</div>
        </div>
      </div>
      {%- endif -%}

    </div>
  </div>

  <!-- BUTTONS -->
  <div class="btn-wrap">
    <button class="btn-cart" id="cs-btn-cart">
      <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" fill="none" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      {{ section.settings.btn_cart_text }}
