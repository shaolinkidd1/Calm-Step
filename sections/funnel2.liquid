<script>
(function(){
  // ── STATE ──
  var _variantId = {{ variant_1.id | default: 'null' }};
  var _cartFeedbackTimer = null;

  // ── TIMER ──
  var timerStr = '{{ section.settings.timer_start }}';
  var parts = timerStr.split(':');
  var _t = (+parts[0]||0)*3600 + (+parts[1]||0)*60 + (+parts[2]||0);
  setInterval(function(){
    _t = _t > 0 ? _t - 1 : 86399;
    var h = String(Math.floor(_t/3600)).padStart(2,'0');
    var m = String(Math.floor((_t%3600)/60)).padStart(2,'0');
    var s = String(_t%60).padStart(2,'0');
    var el = document.getElementById('cs-timer');
    if(el) el.textContent = h+':'+m+':'+s;
  }, 1000);

  // ── VARIANTS + QTY INTEGRADOS ──
  var _productVariants = {{ product.variants | json | default: '[]' }};
  var _selectedOptions = _productVariants.length > 0 ? _productVariants[0].options.slice() : [];
  var _selectedQty = 1;
  var _variantId = _productVariants.length > 0 ? _productVariants[0].id : null;

  function csFormatPrice(cents){
    return '$' + Math.round(cents/100).toLocaleString('es-CL');
  }

  function csFindVariant(options){
    for(var i = 0; i < _productVariants.length; i++){
      var v = _productVariants[i];
      var match = true;
      for(var j = 0; j < options.length; j++){
        if(v.options[j] !== options[j]){ match = false; break; }
      }
      if(match) return v;
    }
    return null;
  }

  function csUpdateStock(variant){
    // Show stock message
    var msgs = document.querySelectorAll('.cs-stock-msg');
    msgs.forEach(function(el){ el.textContent = ''; });
    if(!variant) return;
    var msg = document.getElementById('cs-stock-msg-0');
    if(!msg) return;
    if(!variant.available){
      msg.textContent = '✕ Sin stock';
      msg.className = 'cs-stock-msg low';
    } else if(variant.inventory_quantity > 0 && variant.inventory_quantity <= 5){
      msg.textContent = '⚡ Solo quedan ' + variant.inventory_quantity + ' unidades';
      msg.className = 'cs-stock-msg low';
    } else if(variant.available){
      msg.textContent = '✓ En stock';
      msg.className = 'cs-stock-msg ok';
    }
  }

  function csUpdateButtons(variant){
    var cartBtn = document.getElementById('cs-btn-cart');
    var buyBtn = document.getElementById('cs-btn-buy');
    var sbBuy = document.getElementById('cs-sb-buy-btn');
    var sbCart = document.getElementById('cs-sb-cart-btn');
    var unavailable = !variant || !variant.available;
    [cartBtn, sbCart].forEach(function(b){
      if(!b) return;
      b.disabled = unavailable;
      b.style.opacity = unavailable ? '0.4' : '';
    });
    [buyBtn, sbBuy].forEach(function(b){
      if(!b) return;
      b.disabled = unavailable;
      b.style.opacity = unavailable ? '0.4' : '';
    });
  }

  function csApplyVariant(){
    var variant = csFindVariant(_selectedOptions);
    if(variant){
      _variantId = variant.id;
      // Update price
      if(variant.price){
        var priceEl = document.getElementById('cs-price-display');
        var stickyEl = document.getElementById('cs-sticky-price');
        var f = csFormatPrice(variant.price);
        if(priceEl) priceEl.textContent = f;
        if(stickyEl) stickyEl.textContent = f;
      }
      csUpdateStock(variant);
      csUpdateButtons(variant);
      // Update unavailable state of other option buttons
      csUpdateOptionAvailability();
    } else {
      csUpdateStock(null);
      csUpdateButtons(null);
    }
  }

  function csUpdateOptionAvailability(){
    document.querySelectorAll('.cs-variant-opts').forEach(function(group){
      var optIdx = parseInt(group.getAttribute('data-option-index'));
      group.querySelectorAll('.cs-variant-btn').forEach(function(btn){
        var val = btn.getAttribute('data-value');
        // Check if any variant with this value and current other options is available
        var testOptions = _selectedOptions.slice();
        testOptions[optIdx] = val;
        var v = csFindVariant(testOptions);
        if(!v || !v.available){
          btn.classList.add('unavailable');
        } else {
          btn.classList.remove('unavailable');
        }
      });
    });
  }

  window.csSelectOption = function(btn){
    if(btn.classList.contains('unavailable')) return;
    var optionIndex = parseInt(btn.getAttribute('data-option'));
    var value = btn.getAttribute('data-value');
    _selectedOptions[optionIndex] = value;

    // Update active button
    btn.closest('.cs-variant-opts').querySelectorAll('.cs-variant-btn').forEach(function(b){
      b.classList.remove('active');
    });
    btn.classList.add('active');

    // Update label
    var labelVal = document.getElementById('cs-opt-val-' + optionIndex);
    if(labelVal) labelVal.textContent = value;

    csApplyVariant();
  };

  // Init on load
  csApplyVariant();

  // ── QTY SELECT ──
  // _bundleVariantId: si la opción de qty tiene su propia variante de bundle en Shopify,
  // se usa esa variante con quantity=1 para respetar el precio del pack.
  // Si no tiene variante de bundle, se usa la variante seleccionada × cantidad.
  var _bundleVariantId = null;

  window.csSelectQty = function(el){
    document.querySelectorAll('.qty-card').forEach(function(c){ c.classList.remove('selected'); });
    el.classList.add('selected');
    _selectedQty = parseInt(el.getAttribute('data-qty')) || 1;
    var bundleVid = el.getAttribute('data-variant-id');
    _bundleVariantId = (bundleVid && bundleVid !== '') ? parseInt(bundleVid) : null;
    var price = el.getAttribute('data-price');
    var priceEl = document.getElementById('cs-price-display');
    var stickyEl = document.getElementById('cs-sticky-price');
    if(priceEl && price) priceEl.textContent = price;
    if(stickyEl && price) stickyEl.textContent = price;
  };

  // ── CART COUNT ──
  function updateCartCount(){
    fetch('/cart.js')
      .then(function(r){ return r.json(); })
      .then(function(cart){
        var els = document.querySelectorAll('#cs-cart-count');
        els.forEach(function(el){ el.textContent = cart.item_count; });
      });
  }
  updateCartCount();

  // ── ADD TO CART ──
  function addToCart(){
    // Si hay variante de bundle, la mandamos con qty=1 (el precio ya está en la variante).
    // Si no, mandamos la variante seleccionada con la cantidad elegida.
    var cartId = _bundleVariantId || _variantId;
    var cartQty = _bundleVariantId ? 1 : _selectedQty;
    if(!cartId || cartId === 'null'){
      window.location.href = '/cart';
      return;
    }
    var btn = document.getElementById('cs-btn-cart');
    var sbBtn = document.getElementById('cs-sb-cart-btn');
    var feedback = document.getElementById('cs-cart-feedback');
    if(btn) btn.classList.add('loading');

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: cartId, quantity: cartQty })
    })
    .then(function(r){ return r.json(); })
    .then(function(data){
      if(btn) btn.classList.remove('loading');
      if(data.id){
        updateCartCount();
        if(feedback){
          feedback.textContent = '✓ Agregado al carrito';
          clearTimeout(_cartFeedbackTimer);
          _cartFeedbackTimer = setTimeout(function(){ feedback.textContent = ''; }, 3000);
        }
      } else {
        window.location.href = '/cart';
      }
    })
    .catch(function(){
      if(btn) btn.classList.remove('loading');
      window.location.href = '/cart';
    });
  }

  // ── BUY NOW ──
  function goCheckout(){
    var cartId = _bundleVariantId || _variantId;
    var cartQty = _bundleVariantId ? 1 : _selectedQty;
    if(!cartId || cartId === 'null'){
      window.location.href = '/checkout';
      return;
    }
    window.location.href = '/cart/' + cartId + ':' + cartQty;
  }

  // ── BIND BUTTONS ──
  var btnCart = document.getElementById('cs-btn-cart');
  var btnBuy = document.getElementById('cs-btn-buy');
  var sbCart = document.getElementById('cs-sb-cart-btn');
  var sbBuy = document.getElementById('cs-sb-buy-btn');
  var navCart = document.getElementById('cs-nav-cart-btn');

  if(btnCart) btnCart.addEventListener('click', addToCart);
  if(sbCart) sbCart.addEventListener('click', addToCart);
  if(btnBuy) btnBuy.addEventListener('click', goCheckout);
  if(sbBuy) sbBuy.addEventListener('click', goCheckout);
  if(navCart) navCart.addEventListener('click', function(){ window.location.href = '/cart'; });

  // ── FAQ ──
  window.csFaq = function(el){
    el.parentElement.classList.toggle('open');
  };

  // ── HERO CAROUSEL ──
  (function(){
    var track = document.getElementById('cs-carousel-track');
    if(!track) return;
    var slides = track.querySelectorAll('.cs-carousel-slide');
    var total = slides.length;
    if(total < 2) return;
    var current = 0;
    window._csCarouselIdx = 0;

    function goTo(idx){
      current = (idx + total) % total;
      window._csCarouselIdx = current;
      track.style.transform = 'translateX(-' + (current * 100) + '%)';
      document.querySelectorAll('.cs-carousel-dot').forEach(function(d, i){
        d.classList.toggle('active', i === current);
      });
    }

    window.csCarouselGoTo = goTo;

    // Auto-advance every 4s
    var autoTimer = setInterval(function(){ goTo(current + 1); }, 4000);

    // Touch / swipe
    var startX = 0;
    var hero = document.getElementById('cs-hero-carousel');
    hero.addEventListener('touchstart', function(e){
      startX = e.touches[0].clientX;
      clearInterval(autoTimer);
    }, {passive: true});
    hero.addEventListener('touchend', function(e){
      var dx = e.changedTouches[0].clientX - startX;
      if(Math.abs(dx) > 40){
        goTo(dx < 0 ? current + 1 : current - 1);
      }
      autoTimer = setInterval(function(){ goTo(current + 1); }, 4000);
    }, {passive: true});
  })();
})();
</script>

