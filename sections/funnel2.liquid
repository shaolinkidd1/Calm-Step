    <div class="btn-feedback" id="cs-cart-feedback"></div>
  </div>

  <!-- PAYMENT -->
  <div class="pay-row">
    {%- if section.settings.pay1 != blank -%}<div class="pay-badge">{{ section.settings.pay1 }}</div>{%- endif -%}
    {%- if section.settings.pay2 != blank -%}<div class="pay-badge">{{ section.settings.pay2 }}</div>{%- endif -%}
    {%- if section.settings.pay3 != blank -%}<div class="pay-badge">{{ section.settings.pay3 }}</div>{%- endif -%}
