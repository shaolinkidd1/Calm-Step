{% doc %}
  @prompt
    necesito crear una imagen como para poner mi logo 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-logo-block-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
  }

  .ai-logo-container-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.alignment }};
    align-items: center;
  }

  .ai-logo-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: {{ block.settings.logo_max_width }}px;
  }

  .ai-logo-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-logo-placeholder-{{ ai_gen_id }} {
    background-color: {{ block.settings.placeholder_bg_color }};
    width: 100%;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.border_radius }}px;
    position: relative;
  }

  .ai-logo-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-logo-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: {{ block.settings.empty_state_text_color }};
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-logo-wrapper-{{ ai_gen_id }} {
      max-width: {{ block.settings.logo_max_width_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-logo-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-logo-container-{{ ai_gen_id }}">
    <div class="ai-logo-wrapper-{{ ai_gen_id }}">
      {% if block.settings.logo %}
        {% if block.settings.logo_link %}
          <a href="{{ block.settings.logo_link }}">
            <img
              src="{{ block.settings.logo | image_url: width: 1000 }}"
              alt="{{ block.settings.logo.alt | default: 'Logo' | escape }}"
              loading="lazy"
              width="{{ block.settings.logo.width }}"
              height="{{ block.settings.logo.height }}"
              class="ai-logo-image-{{ ai_gen_id }}"
              style="border-radius: {{ block.settings.border_radius }}px;"
            >
          </a>
        {% else %}
          <img
            src="{{ block.settings.logo | image_url: width: 1000 }}"
            alt="{{ block.settings.logo.alt | default: 'Logo' | escape }}"
            loading="lazy"
            width="{{ block.settings.logo.width }}"
            height="{{ block.settings.logo.height }}"
            class="ai-logo-image-{{ ai_gen_id }}"
            style="border-radius: {{ block.settings.border_radius }}px;"
          >
        {% endif %}
      {% else %}
        <div class="ai-logo-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-logo-empty-state-{{ ai_gen_id }}">
            Agrega tu logo aquí
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Logo",
  "settings": [
    {
      "type": "header",
      "content": "Imagen del logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "url",
      "id": "logo_link",
      "label": "Enlace del logo"
    },
    {
      "type": "range",
      "id": "logo_max_width",
      "label": "Ancho máximo en escritorio",
      "min": 50,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 200
    },
    {
      "type": "range",
      "id": "logo_max_width_mobile",
      "label": "Ancho máximo en móvil",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 150
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Ancho del bloque en escritorio",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Diseño"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alineación",
      "options": [
        {
          "value": "flex-start",
          "label": "Izquierda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "flex-end",
          "label": "Derecha"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Espaciado",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Radio del borde",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colores del marcador"
    },
    {
      "type": "color",
      "id": "placeholder_bg_color",
      "label": "Fondo del marcador",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "empty_state_text_color",
      "label": "Color del texto",
      "default": "#666666"
    }
  ],
  "presets": [
    {
      "name": "Logo"
    }
  ]
}
{% endschema %}
