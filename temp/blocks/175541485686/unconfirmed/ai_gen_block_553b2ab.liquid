{% doc %}
  @prompt
    necesito crear un contador de stock, para generar urgencia
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-stock-counter-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-stock-counter-container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-stock-counter-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: {{ block.settings.text_alignment }};
  }

  .ai-stock-counter-icon-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: {{ block.settings.text_alignment }};
    gap: 8px;
  }

  .ai-stock-counter-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    color: {{ block.settings.icon_color }};
    flex-shrink: 0;
  }

  .ai-stock-counter-message-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    margin: 0;
  }

  .ai-stock-counter-number-{{ ai_gen_id }} {
    color: {{ block.settings.number_color }};
    font-weight: 700;
  }

  .ai-stock-counter-bar-wrapper-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-stock-counter-bar-background-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.bar_height }}px;
    background-color: {{ block.settings.bar_background_color }};
    border-radius: {{ block.settings.bar_border_radius }}px;
    overflow: hidden;
  }

  .ai-stock-counter-bar-fill-{{ ai_gen_id }} {
    height: 100%;
    background-color: {{ block.settings.bar_fill_color }};
    transition: width 0.3s ease;
    border-radius: {{ block.settings.bar_border_radius }}px;
  }

  .ai-stock-counter-subtext-{{ ai_gen_id }} {
    color: {{ block.settings.subtext_color }};
    font-size: {{ block.settings.subtext_size }}px;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-stock-counter-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<stock-counter-{{ ai_gen_id }}
  class="ai-stock-counter-{{ ai_gen_id }}"
  data-stock-remaining="{{ block.settings.stock_remaining }}"
  data-total-stock="{{ block.settings.total_stock }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-stock-counter-container-{{ ai_gen_id }}">
    <div class="ai-stock-counter-content-{{ ai_gen_id }}">
      {% if block.settings.show_icon %}
        <div class="ai-stock-counter-icon-wrapper-{{ ai_gen_id }}">
          <svg
            class="ai-stock-counter-icon-{{ ai_gen_id }}"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            {% if block.settings.icon_style == 'fire' %}
              <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"></path>
            {% elsif block.settings.icon_style == 'clock' %}
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            {% elsif block.settings.icon_style == 'alert' %}
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
              <line x1="12" y1="9" x2="12" y2="13"></line>
              <line x1="12" y1="17" x2="12.01" y2="17"></line>
            {% else %}
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
              <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
              <line x1="12" y1="22.08" x2="12" y2="12"></line>
            {% endif %}
          </svg>
          <p class="ai-stock-counter-message-{{ ai_gen_id }}">
            {{ block.settings.message_before }}
            <span class="ai-stock-counter-number-{{ ai_gen_id }}">{{ block.settings.stock_remaining }}</span>
            {{ block.settings.message_after }}
          </p>
        </div>
      {% else %}
        <p class="ai-stock-counter-message-{{ ai_gen_id }}">
          {{ block.settings.message_before }}
          <span class="ai-stock-counter-number-{{ ai_gen_id }}">{{ block.settings.stock_remaining }}</span>
          {{ block.settings.message_after }}
        </p>
      {% endif %}

      {% if block.settings.show_progress_bar %}
        <div class="ai-stock-counter-bar-wrapper-{{ ai_gen_id }}">
          <div class="ai-stock-counter-bar-background-{{ ai_gen_id }}">
            <div
              class="ai-stock-counter-bar-fill-{{ ai_gen_id }}"
              data-bar-fill
            ></div>
          </div>
        </div>
      {% endif %}

      {% if block.settings.subtext != blank %}
        <p class="ai-stock-counter-subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</p>
      {% endif %}
    </div>
  </div>
</stock-counter-{{ ai_gen_id }}>

<script>
  (function() {
    class StockCounter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.updateProgressBar();
      }

      updateProgressBar() {
        const stockRemaining = parseInt(this.dataset.stockRemaining) || 0;
        const totalStock = parseInt(this.dataset.totalStock) || 100;
        const barFill = this.querySelector('[data-bar-fill]');

        if (barFill) {
          const percentage = Math.min((stockRemaining / totalStock) * 100, 100);
          barFill.style.width = percentage + '%';
        }
      }
    }

    customElements.define('stock-counter-{{ ai_gen_id }}', StockCounter{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Contador de stock",
  "settings": [
    {
      "type": "header",
      "content": "Stock"
    },
    {
      "type": "range",
      "id": "stock_remaining",
      "label": "Unidades restantes",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 15
    },
    {
      "type": "range",
      "id": "total_stock",
      "label": "Stock total",
      "min": 10,
      "max": 500,
      "step": 10,
      "default": 100
    },
    {
      "type": "header",
      "content": "Mensaje"
    },
    {
      "type": "text",
      "id": "message_before",
      "label": "Texto antes del número",
      "default": "¡Solo quedan"
    },
    {
      "type": "text",
      "id": "message_after",
      "label": "Texto después del número",
      "default": "unidades disponibles!"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtexto"
    },
    {
      "type": "header",
      "content": "Icono"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Mostrar icono",
      "default": true
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "Estilo de icono",
      "options": [
        {
          "value": "fire",
          "label": "Fuego"
        },
        {
          "value": "clock",
          "label": "Reloj"
        },
        {
          "value": "alert",
          "label": "Alerta"
        },
        {
          "value": "box",
          "label": "Caja"
        }
      ],
      "default": "fire"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Tamaño del icono",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Color del icono",
      "default": "#D82C0D"
    },
    {
      "type": "header",
      "content": "Barra de progreso"
    },
    {
      "type": "checkbox",
      "id": "show_progress_bar",
      "label": "Mostrar barra de progreso",
      "default": true
    },
    {
      "type": "range",
      "id": "bar_height",
      "label": "Altura de la barra",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "bar_border_radius",
      "label": "Radio de borde de la barra",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "color",
      "id": "bar_background_color",
      "label": "Color de fondo de la barra",
      "default": "#E6E6E6"
    },
    {
      "type": "color",
      "id": "bar_fill_color",
      "label": "Color de relleno de la barra",
      "default": "#D82C0D"
    },
    {
      "type": "header",
      "content": "Estilo"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Ancho en escritorio",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#FFF4F2"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Radio de borde",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Espaciado interno",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alineación del texto",
      "options": [
        {
          "value": "left",
          "label": "Izquierda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Derecha"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Tipografía"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Tamaño del texto",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "text_weight",
      "label": "Peso del texto",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medio"
        },
        {
          "value": "600",
          "label": "Semi-negrita"
        },
        {
          "value": "700",
          "label": "Negrita"
        }
      ],
      "default": "500"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "number_color",
      "label": "Color del número",
      "default": "#D82C0D"
    },
    {
      "type": "range",
      "id": "subtext_size",
      "label": "Tamaño del subtexto",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Color del subtexto",
      "default": "#666666"
    }
  ],
  "presets": [
    {
      "name": "Contador de stock"
    }
  ]
}
{% endschema %}
